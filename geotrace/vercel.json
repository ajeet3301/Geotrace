{
  "routes": [
    { "src": "/js/config.js", "dest": "/api/config" },
    { "src": "/login",        "dest": "/login.html" },
    { "src": "/app",          "dest": "/app.html" },
    { "src": "/admin",        "dest": "/admin.html" },
    { "src": "/live",         "dest": "/live.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control",               "value": "no-store" },
        { "key": "Access-Control-Allow-Origin",  "value": "*" }
      ]
    }
  ]
}
